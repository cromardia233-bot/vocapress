# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# OpenRouter API
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=google/gemini-2.5-pro-preview

# Allowed Telegram user IDs (comma-separated, leave empty for no restriction)
ALLOWED_USER_IDS=

# Polling interval for watch (seconds)
WATCH_INTERVAL=180

# Max tweets per fetch
DEFAULT_FETCH_COUNT=5
MAX_FETCH_COUNT=50
