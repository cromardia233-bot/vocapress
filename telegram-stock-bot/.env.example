# Telegram API credentials (https://my.telegram.org)
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here

# Telegram Bot Token (@BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Telegram phone number for User API session
TELEGRAM_PHONE=+821012345678

# Output channel where filtered messages are sent
# Bot must be admin of this channel
OUTPUT_CHANNEL=@your_output_channel

# OpenAI API Key (https://platform.openai.com)
OPENAI_API_KEY=your_openai_api_key_here
# (Optional) OpenAI-compatible API base URL (default: https://api.openai.com/v1)
# OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Daily digest settings
DAILY_REPORT_HOUR=8
HISTORY_HOURS=24
MESSAGE_FETCH_LIMIT=500
